# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# IDE user-local
.vscode/
.idea/

# Environment & credentials (preventive — never commit secrets)
.env
.env.*
!.env.example
credentials.json
**/credentials.json
*.pem
*.key

# Dependencies
node_modules/

# Cursor (keep rules; ignore local plans/cache/user-local)
.cursor/plans/
*.canvas.tsx
agent-transcripts/

# Internal implementation specs (source docx / extracts — not for public repo)
zzz_ImplmentationGuide/

# Sprint spec extracts anywhere in repo
**/Sprint * Specification-extract.txt
**/sprint*-extract.txt

# Extracted spec scratch files
*.extracted.txt
*.docx.extracted.txt

# Output files (generated deliverables — do not push)
outputs/

# Conversion logs
conversion.log
conversion_report.json

# MCP server config (contains org URLs and auth references)
.cursor/mcp.json

# Terminal output
terminals/

# Legacy internal specs (moved from zzz_*) — keep archive README; exclude bulky binaries/extracts
archive/**
!archive/README.md
archive/**/*.docx
archive/**/*-extract.txt
archive/**/*.extracted.txt

# OneDrive / Office junk
desktop.ini
~$*
*.tmp

# Local Python tooling
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Optional: local scratch under scripts
scripts/_*.py
scripts/**/__pycache__/

#ignore .docx files
*.docx